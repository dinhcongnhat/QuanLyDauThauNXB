datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  INVESTOR
  HEAD_OF_DEPARTMENT
  DIRECTOR
}

enum DocType {
  TT_DUTOAN
  QD_DUTOAN
  TT_KHLCNT
  BC_KHLCNT
  QD_KHLCNT
  // Contractor selection document types
  LCNT_STEP
}

enum DocStatus {
  DRAFT
  PENDING_HEAD
  PENDING_DIRECTOR
  APPROVED
  REJECTED
}

enum ProcurementMethod {
  CHI_DINH_THAU
  CHAO_HANG_CANH_TRANH
  DAU_THAU_RONG_RAI
}

enum ContractPackageType {
  GOI_THAU_TU_VAN
  GOI_THAU_PHI_TU_VAN
  GOI_THAU_TRIEN_KHAI
}

enum StepApprovalStatus {
  NO_APPROVAL_REQUIRED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// ====================== DatSach / Thầu Sách ======================

enum ProcurementType {
  THAU_THIET_BI
  THAU_SACH
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Project {
  id              String          @id @default(uuid())
  tenDuAn         String          @map("ten_du_an")
  procurementType ProcurementType @map("procurement_type")
  status          ProjectStatus   @default(IN_PROGRESS) @map("project_status")
  createdBy       String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  creator             User                 @relation("ProjectCreator", fields: [createdBy], references: [id])
  documents           Document[]            @relation("ProjectDocuments")
  contractorSelections ContractorSelection[] @relation("ProjectContractorSelections")
  payments            Payment[]             @relation("ProjectPayments")
  datSachProjects    DatSachProject[]     @relation("ProjectDatSachProjects")

  @@map("projects")
}

model DatSachProject {
  id              String          @id @default(uuid())
  projectId       String?         @map("project_id")
  parentId        String          @map("parent_id")
  procurementType ProcurementType @default(THAU_SACH) @map("procurement_type")
  tenDuAn         String          @map("ten_du_an")
  status          String          @default("DRAFT")
  qdData          Json            @default("{}") @map("qd_data")
  createdBy       String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  project        Project?     @relation("ProjectDatSachProjects", fields: [projectId], references: [id])
  creator        User         @relation("DatSachProjectCreator", fields: [createdBy], references: [id])
  gdnDocuments   GDNInSach[] @relation("DatSachProjectGdn")
  pcdiDocuments  PCDICoSoIn[] @relation("DatSachProjectPcdi")

  @@map("dat_sach_projects")
}

model GDNInSach {
  id                String          @id @default(uuid())
  datSachProjectId  String          @map("dat_sach_project_id")
  status            String          @default("DRAFT")
  data              Json            @default("{}")
  createdBy         String          @map("created_by")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  datSachProject DatSachProject @relation("DatSachProjectGdn", fields: [datSachProjectId], references: [id])
  creator        User           @relation("GDNInSachCreator", fields: [createdBy], references: [id])
  assignments    GDNAssignment[] @relation("GDNInSachAssignments")

  @@map("gdn_in_sach")
}

model GDNAssignment {
  id            String    @id @default(uuid())
  gdnInSachId  String    @map("gdn_in_sach_id")
  userId        String    @map("user_id")
  assignedBy    String    @map("assigned_by")
  assignedAt    DateTime  @default(now()) @map("assigned_at")
  soLuong       Int       @default(0) @map("so_luong")
  completedAt   DateTime? @map("completed_at")

  gdnInSach GDNInSach @relation("GDNInSachAssignments", fields: [gdnInSachId], references: [id])
  user      User       @relation("GDNAssignmentUser", fields: [userId], references: [id])
  assignee  User       @relation("AssignmentAssignee", fields: [assignedBy], references: [id])

  @@unique([gdnInSachId, userId])
  @@map("gdn_assignments")
}

model PCDICoSoIn {
  id                String          @id @default(uuid())
  datSachProjectId  String          @map("dat_sach_project_id")
  status            String          @default("DRAFT")
  data              Json            @default("{}")
  createdBy         String          @map("created_by")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  datSachProject DatSachProject @relation("DatSachProjectPcdi", fields: [datSachProjectId], references: [id])
  creator        User           @relation("PCDICoSoInCreator", fields: [createdBy], references: [id])

  @@map("pcdi_co_so_in")
}

// StepApprovalRequest must be declared before User since User references it
model StepApprovalRequest {
  id        String   @id @default(uuid())
  stepId    String   @map("step_id")
  userId    String   @map("user_id")
  action    String   // PENDING_APPROVAL, APPROVED, REJECTED
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  step ProcurementStep @relation(fields: [stepId], references: [id])
  user User            @relation(fields: [userId], references: [id])

  @@map("step_approval_requests")
}

enum NotificationType {
  DOC_APPROVED
  DOC_REJECTED
  DOC_SUBMITTED
  GDN_APPROVED
  PCDI_APPROVED
  QD_APPROVED
  STEP_APPROVED
  STEP_REJECTED
  STEP_PENDING_APPROVAL
  STEP_COMPLETED
  PAYMENT_CREATED
  PAYMENT_COMPLETED
  BID_RESULT
  ASSIGNMENT
  PROJECT_COMPLETED
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            Role     @default(INVESTOR)
  isInvestor      Boolean  @default(false) @map("is_investor")
  isContractor    Boolean  @default(false) @map("is_contractor")
  department      String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdDocs          Document[]              @relation("DocCreator")
  delegatedDocs        Document[]              @relation("DocDelegatee")
  assignedDocs         Document[]              @relation("DocAssignee")
  reviews              Review[]
  contractorSelections ContractorSelection[]  @relation("ContractorSelectionCreator")
  stepApprovalRequests StepApprovalRequest[]
  payments             Payment[]               @relation("PaymentCreator")
  bidParticipations    BidParticipation[]      @relation("BidParticipationCreator")
  gdnDocuments         GDNInSach[]            @relation("GDNInSachCreator")
  gdnAssignments       GDNAssignment[]        @relation("GDNAssignmentUser")
  gdnAssignmentsGiven  GDNAssignment[]        @relation("AssignmentAssignee")
  pcdiDocuments        PCDICoSoIn[]           @relation("PCDICoSoInCreator")
  datSachProjects      DatSachProject[]       @relation("DatSachProjectCreator")
  createdProjects      Project[]              @relation("ProjectCreator")
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]

  @@map("users")
}

model RolePermission {
  id            String   @id @default(uuid())
  role          Role
  permissionKey String   @map("permission_key")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([role, permissionKey])
  @@map("roles_permissions")
}

model Document {
  id              String     @id @default(uuid())
  projectId       String?    @map("project_id")
  procurementType ProcurementType? @map("procurement_type")
  type            DocType
  status          DocStatus  @default(DRAFT)
  data            Json       @default("{}")
  parentId        String?    @map("parent_id")
  createdBy       String     @map("created_by")
  delegatedTo     String?    @map("delegated_to")
  assignedTo      String?    @map("assigned_to")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  project         Project?  @relation("ProjectDocuments", fields: [projectId], references: [id])
  creator         User       @relation("DocCreator", fields: [createdBy], references: [id])
  delegatee       User?      @relation("DocDelegatee", fields: [delegatedTo], references: [id])
  assignee        User?      @relation("DocAssignee", fields: [assignedTo], references: [id])
  parent          Document?  @relation("DocParent", fields: [parentId], references: [id])
  children        Document[] @relation("DocParent")
  reviews         Review[]
  contractorSelections ContractorSelection[] @relation("ContractorSelectionDoc")

  @@map("documents")
}

model Review {
  id          String   @id @default(uuid())
  documentId  String   @map("document_id")
  userId      String   @map("user_id")
  action      String
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  document    Document @relation(fields: [documentId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model ContractorSelection {
  id                  String              @id @default(uuid())
  projectId           String?             @map("project_id")
  qdKhlcntId          String              @map("qd_khlcnt_id")
  goiThauIndex        Int                 @map("goi_thau_index")
  tenGoiThau          String              @map("ten_goi_thau")
  procurementMethod   ProcurementMethod   @map("procurement_method")
  data                Json                @default("{}")
  createdBy           String              @map("created_by")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  contractPackageType  ContractPackageType? @map("contract_package_type")

  project             Project?             @relation("ProjectContractorSelections", fields: [projectId], references: [id])
  qdKhlcnt            Document            @relation("ContractorSelectionDoc", fields: [qdKhlcntId], references: [id])
  creator             User                @relation("ContractorSelectionCreator", fields: [createdBy], references: [id])
  steps               ProcurementStep[]
  payments            Payment[]

  @@unique([qdKhlcntId, goiThauIndex])
  @@map("contractor_selections")
}

model ProcurementStep {
  id                    String              @id @default(uuid())
  contractorSelectionId String              @map("contractor_selection_id")
  stepKey               String              @map("step_key")
  stepOrder             Int                 @map("step_order")
  title                 String
  status                String              @default("NOT_STARTED")
  data                  Json                @default("{}")
  attachmentPath        String?             @map("attachment_path")
  completedAt           DateTime?           @map("completed_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  // Approval fields
  requiresApproval      Boolean             @default(false) @map("requires_approval")
  approvalStatus       StepApprovalStatus  @default(NO_APPROVAL_REQUIRED) @map("approval_status")
  approvedBy           String?             @map("approved_by")
  approvedAt           DateTime?           @map("approved_at")
  approverRole         String?             @map("approver_role")
  approvalComment      String?             @map("approval_comment")

  contractorSelection   ContractorSelection @relation(fields: [contractorSelectionId], references: [id])
  approvalRequests      StepApprovalRequest[]

  @@unique([contractorSelectionId, stepKey])
  @@map("procurement_steps")
}

model Payment {
  id                    String              @id @default(uuid())
  projectId             String?             @map("project_id")
  contractorSelectionId String              @map("contractor_selection_id")
  contractPackageType   ContractPackageType @map("contract_package_type")
  maSoHD                String?             @map("ma_so_hd")
  data                  Json                @default("{}")
  createdBy             String              @map("created_by")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  project             Project?             @relation("ProjectPayments", fields: [projectId], references: [id])
  contractorSelection ContractorSelection   @relation(fields: [contractorSelectionId], references: [id])
  creator             User                  @relation("PaymentCreator", fields: [createdBy], references: [id])
  steps              PaymentStep[]

  @@map("payments")
}

model PaymentStep {
  id            String   @id @default(uuid())
  paymentId     String   @map("payment_id")
  stepKey       String   @map("step_key")
  stepOrder     Int      @map("step_order")
  title         String
  status        String   @default("NOT_STARTED")
  data          Json     @default("{}")
  attachmentPath String? @map("attachment_path")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payment       Payment  @relation(fields: [paymentId], references: [id])

  @@unique([paymentId, stepKey])
  @@map("payment_steps")
}

// ====================== Nhà thầu - Tham dự đấu thầu ======================

enum BidResult {
  PENDING
  WON
  LOST
}

// ====================== Document Library ======================

enum LibraryType {
  THONG_TIN_TO_CHUC
  THONG_TIN_NHA_THAU
  DIA_CHI
  KY_TUONG
  CUSTOM
}

enum FieldType {
  TEXT
  TEXTAREA
  DATE
  MONEY
  NUMBER
  EMAIL
  PHONE
}

model Organization {
  id        String      @id @default(cuid())
  ten       String
  moTa      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  libraries Library[]

  @@map("organizations")
}

model Library {
  id             String       @id @default(cuid())
  ten            String
  loai           LibraryType
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fields         LibraryField[]
  savedValues    SavedValue[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("libraries")
}

model LibraryField {
  id            String     @id @default(cuid())
  libraryId     String     @map("library_id")
  library       Library    @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  tenTruong     String     @map("ten_truong")
  khoa          String     @unique @default(cuid())
  kieuDuLieu    FieldType  @map("kieu_du_lieu")
  giaTriMacDinh String?    @map("gia_tri_mac_dinh")
  batBuoc       Boolean    @default(false) @map("bat_buoc")
  thuTu         Int        @default(0) @map("thu_tu")
  nhom          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("library_fields")
}

model SavedValue {
  id        String   @id @default(cuid())
  libraryId String   @map("library_id")
  library   Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  tenGiaTri String   @map("ten_gia_tri")
  duLieu    Json     @map("du_lieu")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("saved_values")
}

model BidParticipation {
  id                String      @id @default(uuid())
  maThongBaoMoiThau String      @map("ma_thong_bao_moi_thau")
  tenChuDauTu       String      @map("ten_chu_dau_tu")
  tenGoiThau        String?     @map("ten_goi_thau")
  result            BidResult   @default(PENDING)
  data              Json        @default("{}")
  createdBy         String      @map("created_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  creator           User        @relation("BidParticipationCreator", fields: [createdBy], references: [id])
  steps             BidStep[]

  @@map("bid_participations")
}

model BidStep {
  id                  String    @id @default(uuid())
  bidParticipationId  String    @map("bid_participation_id")
  stepKey             String    @map("step_key")
  stepOrder           Int       @map("step_order")
  title               String
  status              String    @default("NOT_STARTED")
  data                Json      @default("{}")
  attachments         Json      @default("[]")
  completedAt         DateTime? @map("completed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  bidParticipation    BidParticipation @relation(fields: [bidParticipationId], references: [id])

  @@unique([bidParticipationId, stepKey])
  @@map("bid_steps")
}
